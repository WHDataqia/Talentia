# Configuración PostgreSQL para SoftRRHH
# Copiar este archivo como .env en la raíz del proyecto

# ====== POSTGRESQL ======
DATABASE_URL=postgresql://softrrh_user:tu_contraseña_segura@localhost:5432/softrrh

# Usuario de PostgreSQL a usar
DB_USER=softrrh_user
DB_PASSWORD=tu_contraseña_segura
DB_HOST=localhost
DB_PORT=5432
DB_NAME=softrrh

# ====== CONEXIÓN ======
# Pool de conexiones
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ====== SERVIDOR FLASK ======
FLASK_ENV=production
SECRET_KEY=tu_clave_secreta_aqui
DEBUG=False

# ====== LOGGING ======
LOG_LEVEL=INFO
LOG_FILE=app.log

# Ejemplos de conexión PostgreSQL:

# LOCAL (desarrollo):
# DATABASE_URL=postgresql://softrrh_user:password123@localhost:5432/softrrh

# REMOTO (producción):
# DATABASE_URL=postgresql://user:password@server.com:5432/softrrh

# HEROKU:
# DATABASE_URL=postgresql://user:password@ec2-xxx.compute-1.amazonaws.com:5432/softrrh

# AZURE:
# DATABASE_URL=postgresql://user@servername:password@servername.postgres.database.azure.com:5432/softrrh
